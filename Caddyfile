# OpenClaw reverse proxy — terminates TLS and forwards to the api container.
#
# Domain mode (recommended): set DASHBOARD_DOMAIN in .env to a hostname that
# points at this VPS, then run:
#   docker compose exec caddy sh -c 'echo done'   # (compose substitutes $DASHBOARD_DOMAIN)
# Caddy automatically obtains and renews a Let's Encrypt certificate.
{$DASHBOARD_DOMAIN:localhost} {
	reverse_proxy api:8001
	encode gzip

	# IP-only / no-DNS fallback: when DASHBOARD_DOMAIN is unset (or "localhost"),
	# Caddy issues a self-signed "internal" cert instead of attempting ACME,
	# so HTTPS still works without a real domain. Remove this block once
	# DASHBOARD_DOMAIN is a real hostname — Caddy will then use Let's Encrypt.
	tls internal
}
