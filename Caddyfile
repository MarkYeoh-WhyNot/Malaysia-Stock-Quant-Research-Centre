# OpenClaw reverse proxy — terminates TLS and forwards to the api container.
#
# TLS clients don't send SNI for IP literals (RFC 6066), so a plain
# domain-keyed site block never matches bare-IP connections and the
# handshake fails with "no certificate available". `default_sni` tells Caddy
# which certificate to serve when no SNI is presented, so IP-only access
# works with the self-signed "internal" cert below.
#
# Domain mode: once DASHBOARD_DOMAIN in .env is a real hostname pointing at
# this VPS, remove the `tls internal` line — Caddy will automatically obtain
# and renew a Let's Encrypt certificate instead (default_sni can stay).
{
	default_sni {$DASHBOARD_DOMAIN:localhost}
}

{$DASHBOARD_DOMAIN:localhost} {
	reverse_proxy api:8001
	encode gzip
	tls internal
}
