# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OANDA Broker (legacy FX — unused for KLSE, safe to leave blank)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# Notifications (optional but recommended)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ALLOWED_CHATS=your_telegram_chat_id_here
TELEGRAM_INTAKE_CHATS=
# Chat that receives operational alerts (daemon crash/restart, budget exhausted).
# Defaults to TELEGRAM_CHAT_ID if unset.
ALERT_TELEGRAM_CHAT_ID=

# Discord (optional)
DISCORD_WEBHOOK_URL=

# Brave Search API
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Semantic Scholar (optional — raises rate limits for research hunting)
SEMANTIC_SCHOLAR_API_KEY=

# Dashboard security
# Shared secret required in the X-API-Key header for all /api endpoints
# (except /api/health). Generate with: openssl rand -hex 32
OPENCLAW_API_KEY=change_me_generate_a_long_random_string
# Origin allowed by CORS, e.g. https://openclaw.example.com
DASHBOARD_ORIGIN=http://localhost

# CPO module
CPO_ENABLED=true

# Budget
AI_DAILY_BUDGET_USD=50

# Logging
LOG_LEVEL=INFO
